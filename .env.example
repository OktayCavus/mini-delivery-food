# Production profili için environment variable tanımla (SPRING_PROFILES_ACTIVE=prod)
# Lokal geliştirmede application-local.properties kullanılır; bu dosya opsiyoneldir.

DB_URL=jdbc:postgresql://localhost:5432/mini_delivery_food_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
JWT_SECRET=your_jwt_secret_at_least_256_bits_here
JWT_EXPIRATION=3600000
